<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_vocabulary_tree" model="ir.ui.view">
        <field name="name">english.vocabulary.tree</field>
        <field name="model">english.vocabulary</field>
        <field name="arch" type="xml">
            <tree>
                <field name="word"/>
                <field name="meaning"/>
                <field name="category"/>
                <field name="difficulty"/>
                <field name="active"/>
            </tree>
        </field>
    </record>

    <record id="view_vocabulary_form" model="ir.ui.view">
        <field name="name">english.vocabulary.form</field>
        <field name="model">english.vocabulary</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <field name="word"/>
                        <field name="meaning"/>
                        <field name="pronunciation"/>
                        <field name="example"/>
                        <field name="category"/>
                        <field name="difficulty"/>
                        <field name="active"/>
                    </group>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <record id="action_vocabulary" model="ir.actions.act_window">
        <field name="name">Vocabulary</field>
        <field name="res_model">english.vocabulary</field>
        <field name="view_mode">tree,form</field>
    </record>
</odoo>