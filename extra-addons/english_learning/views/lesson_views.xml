<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_lesson_tree" model="ir.ui.view">
        <field name="name">english.lesson.tree</field>
        <field name="model">english.lesson</field>
        <field name="arch" type="xml">
            <tree>
                <field name="name"/>
                <field name="description"/>
                <field name="active"/>
            </tree>
        </field>
    </record>

    <record id="view_lesson_form" model="ir.ui.view">
        <field name="name">english.lesson.form</field>
        <field name="model">english.lesson</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="description"/>
                    </group>
                    <notebook>
                        <page string="Vocabulary">
                            <field name="vocabulary_ids" widget="many2many_tags"/>
                        </page>
                        <page string="Quizzes">
                            <field name="quiz_ids"/>
                        </page>
                    </notebook>
                    <group>
                        <field name="active"/>
                    </group>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <record id="action_lesson" model="ir.actions.act_window">
        <field name="name">Lessons</field>
        <field name="res_model">english.lesson</field>
        <field name="view_mode">tree,form</field>
    </record>
</odoo>